<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@mipmap/img_recommend_background"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/ll_secondary_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_60"
        android:layout_below="@+id/tv_play_sing"
        android:orientation="horizontal"
        android:gravity="center">
        <ImageView
            android:id="@+id/iv_secondary_home"
            android:layout_width="@dimen/dp_50"
            android:layout_height="@dimen/dp_50"
            android:layout_below="@+id/tv_play_sing"
            android:padding="@dimen/dp_10"
            android:layout_marginLeft="@dimen/dp_12"
            android:src="@mipmap/ic_recommend_home"/>

        <TextView
            android:id="@+id/tv_secondary_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_E6E6E6"
            android:textSize="@dimen/dp_26"
            android:text="点唱/分类点歌"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/ll_secondary_title"
        android:layout_above="@+id/tv_back"
        android:gravity="center">
        <FrameLayout
            android:id="@+id/fl_hot_song"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_marginLeft="@dimen/dp_18">

            <ImageView
                android:id="@+id/iv_special_offer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_special_offer"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="热门歌曲"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_original_singer_song"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_toRightOf="@+id/fl_hot_song"
            android:layout_marginLeft="@dimen/dp_8">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_use_intruction"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="原唱歌曲"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_ktv_area"
            android:layout_width="@dimen/dp_408"
            android:layout_height="@dimen/dp_214"
            android:layout_toRightOf="@+id/fl_original_singer_song"
            android:layout_marginLeft="@dimen/dp_8">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_weather"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="KTV专区"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_classic_old_songs"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_toRightOf="@+id/fl_ktv_area"
            android:layout_marginLeft="@dimen/dp_8">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_use_intruction"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="经典老歌"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_film_hot_song"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_below="@+id/fl_hot_song"
            android:layout_marginLeft="@dimen/dp_18"
            android:layout_marginTop="@dimen/dp_8"
            android:layout_centerVertical="true">

            <ImageView
                android:id="@+id/iv_consumer_details"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_consumer_details"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="影视热歌"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_youth_campus"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_toRightOf="@+id/fl_film_hot_song"
            android:layout_alignTop="@+id/fl_film_hot_song"
            android:layout_marginLeft="@dimen/dp_8"
            android:layout_centerVertical="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_my_connection"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="青春校园"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_antiquity"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_toRightOf="@+id/fl_youth_campus"
            android:layout_alignTop="@+id/fl_film_hot_song"
            android:layout_marginLeft="@dimen/dp_8"
            android:layout_centerVertical="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_situational_sound_effects"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="古风"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_folk_song"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_toRightOf="@+id/fl_antiquity"
            android:layout_alignTop="@+id/fl_film_hot_song"
            android:layout_marginLeft="@dimen/dp_8"
            android:layout_centerVertical="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_disconnect_phone"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="民歌"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_spring_blossoms"
            android:layout_width="@dimen/dp_200"
            android:layout_height="@dimen/dp_214"
            android:layout_toRightOf="@+id/fl_folk_song"
            android:layout_alignTop="@+id/fl_film_hot_song"
            android:layout_marginLeft="@dimen/dp_8"
            android:layout_centerVertical="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@mipmap/img_my_connection"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:gravity="center"
                android:textSize="@dimen/dp_28"
                android:textColor="@color/white"
                android:text="春暖花开"/>
        </FrameLayout>

    </RelativeLayout>


    <TextView
        android:id="@+id/tv_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@mipmap/img_recommend_back"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:layout_marginBottom="@dimen/dp_10"
        android:layout_marginRight="@dimen/dp_20"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_28"
        android:gravity="center"
        android:text="返回"/>
</RelativeLayout>
