<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_140"
    android:background="@mipmap/img_background"
    android:orientation="horizontal"
    android:layout_alignParentBottom="true"
    android:gravity="center"
    android:layout_toRightOf="@+id/ll_left_category"
    tools:context=".MainActivity">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableTop="@drawable/btn_cut_song_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="切歌"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:drawableTop="@drawable/btn_play_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="播放"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:drawableTop="@drawable/btn_re_sing_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="重唱"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:drawableTop="@drawable/btn_original_singer_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="原唱"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:drawableTop="@drawable/btn_vol_add_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="放音"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:layout_marginRight="@dimen/dp_20"
        android:orientation="horizontal"
        android:gravity="center">

        <FrameLayout
            android:layout_width="@dimen/dp_80"
            android:layout_height="@dimen/dp_80">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@mipmap/ic_logo"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_play"/>
            <com.victor.ktv.widget.Indicator
                android:id="@+id/indicator_voice"
                android:layout_width="@dimen/dp_34"
                android:layout_height="@dimen/dp_34"
                android:layout_gravity="center"
                app:bar_num="4"
                app:indicator_bar_color="@color/white"
                app:step_num="10"
                app:duration="4000"
                android:background="@color/transparent"/>
        </FrameLayout>

        <RelativeLayout
            android:layout_width="@dimen/dp_120"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dp_10">

            <TextView
                android:id="@+id/tv_song_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="@dimen/dp_18"
                android:text="静悄悄..."/>
            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_song_name"
                android:layout_marginTop="@dimen/dp_2"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="@dimen/dp_13"
                android:text="00:40"/>
            <ProgressBar
                android:id="@+id/pb_play_progress"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_2"
                android:layout_below="@+id/tv_time"
                android:layout_marginTop="@dimen/dp_2"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progressDrawable="@drawable/bg_play_progress_bar"
                android:progress="50"
                android:max="100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_below="@+id/pb_play_progress"
                android:drawableLeft="@drawable/btn_rewind_selector"
                android:drawablePadding="@dimen/dp_10"
                android:clickable="true"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="@dimen/dp_13"
                android:text="快退"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_below="@+id/pb_play_progress"
                android:drawableRight="@drawable/btn_forward_selector"
                android:drawablePadding="@dimen/dp_10"
                android:layout_alignParentRight="true"
                android:clickable="true"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="@dimen/dp_13"
                android:text="快进"/>
        </RelativeLayout>
    </LinearLayout>


    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginLeft="@dimen/dp_20">
        <TextView
            android:id="@+id/tv_songs_ordered"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableTop="@drawable/btn_ordered_selector"
            android:clickable="true"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="@dimen/dp_18"
            android:text="已点"/>

        <TextView
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_20"
            android:background="@drawable/bg_ordered_count"
            android:gravity="center"
            android:textSize="@dimen/dp_12"
            android:textColor="@color/white"
            android:layout_gravity="right"
            android:text="1"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_vol_ajustment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:drawableTop="@drawable/btn_tuning_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="调音"/>
    <TextView
        android:id="@+id/tv_ctrl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:drawableTop="@drawable/btn_control_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="控制"/>
    <TextView
        android:id="@+id/tv_atmosphere"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:drawableTop="@drawable/btn_atmosphere_selector"
        android:drawablePadding="@dimen/dp_5"
        android:clickable="true"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="气氛"/>

    <ImageView
        android:layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_42"
        android:layout_marginLeft="@dimen/dp_20"
        android:src="@mipmap/ic_phone_order"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_10"
        android:drawablePadding="@dimen/dp_5"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_18"
        android:text="手机\n点歌"/>
</LinearLayout>
