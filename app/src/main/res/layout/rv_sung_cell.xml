<RelativeLayout
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingLeft="@dimen/dp_10"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_10"
        android:singleLine="true"
        android:textColor="@color/white"
        android:textSize="@dimen/dp_24"
        android:text="十年 HD"/>

    <ImageView
        android:id="@+id/iv_mv"
        android:layout_width="@dimen/dp_28"
        android:layout_height="@dimen/dp_18"
        android:layout_below="@+id/tv_title"
        android:layout_marginTop="@dimen/dp_10"
        android:src="@mipmap/ic_mv"/>

    <TextView
        android:id="@+id/tv_singer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_title"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_toRightOf="@+id/iv_mv"
        android:textSize="@dimen/dp_16"
        android:textColor="#fafafa"
        android:text="陈奕迅"/>

    <ImageView
        android:id="@+id/iv_operating"
        android:layout_width="@dimen/dp_30"
        android:layout_height="@dimen/dp_30"
        android:layout_toLeftOf="@+id/view_line"
        android:layout_centerVertical="true"
        android:src="@mipmap/ic_ordered_dlg_add"/>

    <View
        android:id="@+id/view_line"
        android:layout_width="@dimen/dp_1"
        android:layout_height="@dimen/dp_25"
        android:layout_toLeftOf="@+id/iv_del"
        android:layout_marginLeft="@dimen/dp_20"
        android:layout_marginRight="@dimen/dp_20"
        android:layout_centerVertical="true"
        android:background="@color/white"/>

    <ImageView
        android:id="@+id/iv_del"
        android:layout_width="@dimen/dp_30"
        android:layout_height="@dimen/dp_30"
        android:layout_marginRight="@dimen/dp_40"
        android:layout_centerVertical="true"
        android:layout_alignParentRight="true"
        android:src="@mipmap/ic_ordered_dlg_fav"/>

</RelativeLayout>

